<Layouts.app flash={@flash} fullscreen>
  <div class="flex flex-col h-full">
    <%!-- Workspace Header --%>
    <div class="flex items-center justify-between px-2 py-3 border-b border-base-300">
      <div class="flex items-center gap-3">
        <.link navigate={~p"/workspaces"} class="btn btn-ghost btn-sm">
          <.icon name="hero-arrow-left" class="w-4 h-4" />
        </.link>
        <h1 class="text-lg font-semibold tracking-tight">{@workspace.name}</h1>
        <span class="text-xs text-base-content/50">{length(@agent_sessions)} agent(s)</span>
      </div>
      <div class="flex items-center gap-2">
        <%= if @agent_sessions != [] do %>
          <div class="flex items-center border border-base-300 rounded-lg overflow-hidden">
            <button
              id="view-split-btn"
              phx-click="toggle_view_mode"
              class={[
                "btn btn-ghost btn-xs rounded-none border-0",
                if(@view_mode == :split, do: "bg-base-300", else: "opacity-50")
              ]}
              title="Split view"
            >
              <.icon name="hero-view-columns" class="w-4 h-4" />
            </button>
            <button
              id="view-unified-btn"
              phx-click="toggle_view_mode"
              class={[
                "btn btn-ghost btn-xs rounded-none border-0",
                if(@view_mode == :unified, do: "bg-base-300", else: "opacity-50")
              ]}
              title="Unified view"
            >
              <.icon name="hero-chat-bubble-left-right" class="w-4 h-4" />
            </button>
          </div>
          <button
            id="toggle-task-board-btn"
            phx-click="toggle_task_board"
            class={[
              "btn btn-ghost btn-sm",
              if(@show_task_board, do: "text-primary", else: "text-base-content/60")
            ]}
            title="Task Board"
          >
            <.icon name="hero-clipboard-document-check" class="w-4 h-4" /> Tasks
          </button>
          <button
            id="clear-team-btn"
            phx-click="clear_team"
            data-confirm="Clear all conversations? This cannot be undone."
            class="btn btn-ghost btn-sm text-error/70 hover:text-error"
          >
            <.icon name="hero-trash" class="w-4 h-4" /> Clear
          </button>
        <% end %>
        <button
          class="btn btn-primary btn-sm"
          onclick="document.getElementById('add-agent-dialog').showModal()"
        >
          <.icon name="hero-plus" class="w-4 h-4" /> Add Agent
        </button>
      </div>
    </div>

    <%!-- Agent Columns --%>
    <%= if @agent_sessions == [] do %>
      <div class="flex-1 flex items-center justify-center">
        <div class="text-center space-y-4 max-w-sm">
          <div class="text-6xl">🤖</div>
          <h2 class="text-xl font-semibold">No agents yet</h2>
          <p class="text-base-content/60 text-sm">
            Add an agent from the catalog to start chatting.
          </p>
          <button
            class="btn btn-primary"
            onclick="document.getElementById('add-agent-dialog').showModal()"
          >
            <.icon name="hero-plus" class="w-4 h-4" /> Add Your First Agent
          </button>
        </div>
      </div>
    <% else %>
      <%!-- ============================================= --%>
      <%!-- SPLIT MODE                                    --%>
      <%!-- ============================================= --%>
      <%= if @view_mode == :split do %>
        <div class="flex-1 flex min-h-0">
          <div class="flex-1 flex overflow-x-auto min-h-0">
            <%= for session <- @agent_sessions do %>
              <% colors = Catalog.agent_color(session.agent_profile_id, session.display_name) %>
              <div class="flex flex-col flex-1 min-w-[300px] border-r border-base-300/50 last:border-r-0 agent-column-enter transition-all duration-200">
                <%!-- Agent Header --%>
                <div class={[
                  "flex items-center justify-between px-3 py-2 border-b",
                  colors.header
                ]}>
                  <div class="flex items-center gap-2 min-w-0">
                    <div class={[
                      "w-2 h-2 rounded-full shrink-0",
                      colors.dot
                    ]}>
                    </div>
                    <span class="font-medium text-sm truncate">{session.display_name}</span>
                    <span class="text-xs opacity-60 shrink-0">{session.agent_profile_id}</span>
                  </div>
                  <div class="flex items-center gap-1 shrink-0">
                    <%= if Map.get(@agent_statuses, session.id) == :busy do %>
                      <span class="loading loading-dots loading-xs text-warning"></span>
                    <% end %>
                    <button
                      phx-click="remove_agent"
                      phx-value-session-id={session.id}
                      data-confirm="Remove this agent? Chat history will be preserved."
                      class="btn btn-ghost btn-xs opacity-40 hover:opacity-100"
                    >
                      <.icon name="hero-x-mark" class="w-3 h-3" />
                    </button>
                  </div>
                </div>

                <%!-- Messages --%>
                <div
                  id={"messages-#{session.id}"}
                  phx-hook=".AutoScroll"
                  class="flex-1 overflow-y-auto px-3 py-2 space-y-3"
                >
                  <% stream =
                    Map.get(@streaming, session.id, %{
                      content: "",
                      thinking: "",
                      tool_calls: [],
                      usage: nil
                    }) %>
                  <%= if Map.get(@messages, session.id, []) == [] and stream.content == "" and stream.tool_calls == [] do %>
                    <div class="flex items-center justify-center h-full text-base-content/40 text-sm">
                      Send a message to start chatting
                    </div>
                  <% end %>
                  <%= for msg <- Map.get(@messages, session.id, []) do %>
                    <div
                      id={"msg-#{msg.id}"}
                      class={[
                        "flex flex-col gap-0.5",
                        if(msg.role == "user", do: "items-end", else: "items-start")
                      ]}
                    >
                      <span class="text-[10px] uppercase tracking-wider text-base-content/40 px-1">
                        {msg.sender_name || msg.role}
                      </span>

                      <%!-- Thinking trace (collapsible) --%>
                      <%= if Map.get(msg, :thinking) do %>
                        <details class="w-full max-w-[85%] group">
                          <summary class="flex items-center gap-1.5 cursor-pointer text-xs text-base-content/50 hover:text-base-content/70 px-1 py-0.5 transition-colors">
                            <.icon name="hero-light-bulb" class="w-3 h-3" />
                            <span>Thinking...</span>
                            <.icon
                              name="hero-chevron-right"
                              class="w-3 h-3 transition-transform group-open:rotate-90"
                            />
                          </summary>
                          <div class="mt-1 rounded-lg bg-base-200/50 border border-base-300/50 px-3 py-2 text-xs text-base-content/60 whitespace-pre-wrap break-words">
                            {msg.thinking}
                          </div>
                        </details>
                      <% end %>

                      <%!-- Tool calls (collapsible) --%>
                      <%= for tc <- Map.get(msg, :tool_calls, []) do %>
                        <details class="w-full max-w-[85%] group">
                          <summary class="flex items-center gap-1.5 cursor-pointer text-xs px-1 py-0.5 transition-colors hover:text-base-content/70">
                            <.icon
                              name="hero-wrench-screwdriver"
                              class="w-3 h-3 text-base-content/50"
                            />
                            <span class="font-medium">{tc.name}</span>
                            <%= cond do %>
                              <% tc.status == :completed -> %>
                                <span class="text-success/70 text-[10px]">Completed</span>
                              <% tc.status == :error -> %>
                                <span class="text-error/70 text-[10px]">Error</span>
                              <% true -> %>
                                <span class="loading loading-spinner loading-xs text-warning">
                                </span>
                            <% end %>
                            <.icon
                              name="hero-chevron-right"
                              class="w-3 h-3 text-base-content/40 transition-transform group-open:rotate-90"
                            />
                          </summary>
                          <div class="mt-1 rounded-lg border border-base-300/50 text-xs overflow-hidden">
                            <%= if tc.args && tc.args != %{} do %>
                              <div class="bg-base-200/30 px-3 py-1.5 border-b border-base-300/50">
                                <span class="text-[10px] uppercase tracking-wider text-base-content/40">
                                  Arguments
                                </span>
                                <pre class="mt-0.5 text-base-content/70 whitespace-pre-wrap break-words">{Jason.encode!(tc.args, pretty: true)}</pre>
                              </div>
                            <% end %>
                            <%= if tc.result do %>
                              <div class="bg-base-200/20 px-3 py-1.5">
                                <span class="text-[10px] uppercase tracking-wider text-base-content/40">
                                  Result
                                </span>
                                <div class="mt-0.5 text-base-content/70 whitespace-pre-wrap break-words">
                                  {tc.result}
                                </div>
                              </div>
                            <% end %>
                          </div>
                        </details>
                      <% end %>

                      <%!-- Message content --%>
                      <%= if msg.content && msg.content != "" do %>
                        <% inter_agent? =
                          msg.role == "user" and msg.sender_name != "You" and
                            msg.sender_name != nil %>
                        <div class={[
                          "rounded-xl px-3 py-2 text-sm max-w-[85%] break-words",
                          cond do
                            msg.role != "user" ->
                              "bg-base-200 text-base-content rounded-bl-sm prose prose-sm max-w-none"

                            inter_agent? ->
                              [
                                Catalog.agent_color(nil, msg.sender_name).dot,
                                "text-white rounded-br-sm whitespace-pre-wrap"
                              ]

                            true ->
                              "bg-primary text-primary-content rounded-br-sm whitespace-pre-wrap"
                          end
                        ]}>
                          <%= if msg.role == "user" do %>
                            {msg.content}
                          <% else %>
                            {Markdown.render(msg.content)}
                          <% end %>
                        </div>
                        <%!-- Usage info --%>
                        <%= if Map.get(msg, :usage) do %>
                          <div class="group/usage relative inline-flex items-center px-1">
                            <.icon
                              name="hero-information-circle"
                              class="w-3 h-3 text-base-content/30 hover:text-base-content/60 cursor-help transition-colors"
                            />
                            <div class="absolute bottom-full left-0 mb-1 hidden group-hover/usage:block z-10">
                              <div class="bg-base-300 text-base-content text-[10px] rounded-lg px-2.5 py-1.5 shadow-lg border border-base-content/10 whitespace-nowrap">
                                <div class="flex items-center gap-3">
                                  <span>{Map.get(msg.usage, :input_tokens, 0)} in</span>
                                  <span>{Map.get(msg.usage, :output_tokens, 0)} out</span>
                                  <span class="font-medium">
                                    {Map.get(msg.usage, :total_tokens, 0)} total
                                  </span>
                                  <%= if Map.get(msg.usage, :duration_ms) do %>
                                    <span class="text-base-content/50">
                                      {Float.round(msg.usage.duration_ms / 1000, 1)}s
                                    </span>
                                  <% end %>
                                </div>
                                <%= if Map.get(msg.usage, :model) do %>
                                  <div class="text-base-content/50 mt-0.5">{msg.usage.model}</div>
                                <% end %>
                              </div>
                            </div>
                          </div>
                        <% end %>
                      <% end %>
                    </div>
                  <% end %>

                  <%!-- Streaming thinking --%>
                  <%= if stream.thinking != "" do %>
                    <div class="flex flex-col gap-0.5 items-start">
                      <details open class="w-full max-w-[85%] group">
                        <summary class="flex items-center gap-1.5 cursor-pointer text-xs text-base-content/50 hover:text-base-content/70 px-1 py-0.5 transition-colors">
                          <.icon name="hero-light-bulb" class="w-3 h-3" />
                          <span>Thinking...</span>
                          <span class="loading loading-dots loading-xs text-base-content/40">
                          </span>
                          <.icon
                            name="hero-chevron-right"
                            class="w-3 h-3 transition-transform group-open:rotate-90"
                          />
                        </summary>
                        <div class="mt-1 rounded-lg bg-base-200/50 border border-base-300/50 px-3 py-2 text-xs text-base-content/60 whitespace-pre-wrap break-words">
                          {stream.thinking}
                        </div>
                      </details>
                    </div>
                  <% end %>

                  <%!-- Streaming tool calls --%>
                  <%= for tc <- stream.tool_calls do %>
                    <div class="flex flex-col gap-0.5 items-start">
                      <details open class="w-full max-w-[85%] group">
                        <summary class="flex items-center gap-1.5 cursor-pointer text-xs px-1 py-0.5 transition-colors hover:text-base-content/70">
                          <.icon
                            name="hero-wrench-screwdriver"
                            class="w-3 h-3 text-base-content/50"
                          />
                          <span class="font-medium">{tc.name}</span>
                          <%= if tc.status == :completed do %>
                            <span class="text-success/70 text-[10px]">Completed</span>
                          <% else %>
                            <span class="text-error/70 text-[10px]">Error</span>
                          <% end %>
                          <.icon
                            name="hero-chevron-right"
                            class="w-3 h-3 text-base-content/40 transition-transform group-open:rotate-90"
                          />
                        </summary>
                        <%= if tc.result do %>
                          <div class="mt-1 rounded-lg border border-base-300/50 text-xs overflow-hidden">
                            <div class="bg-base-200/20 px-3 py-1.5">
                              <span class="text-[10px] uppercase tracking-wider text-base-content/40">
                                Result
                              </span>
                              <div class="mt-0.5 text-base-content/70 whitespace-pre-wrap break-words">
                                {tc.result}
                              </div>
                            </div>
                          </div>
                        <% end %>
                      </details>
                    </div>
                  <% end %>

                  <%!-- Streaming tokens --%>
                  <%= if stream.content != "" do %>
                    <div class="flex flex-col gap-0.5 items-start">
                      <span class="text-[10px] uppercase tracking-wider text-base-content/40 px-1">
                        assistant
                      </span>
                      <div class="bg-base-200 text-base-content rounded-xl rounded-bl-sm px-3 py-2 text-sm max-w-[85%] whitespace-pre-wrap break-words">
                        {stream.content}
                        <span class="inline-block w-1 h-4 bg-primary animate-pulse ml-0.5 align-text-bottom">
                        </span>
                      </div>
                    </div>
                  <% end %>
                </div>

                <%!-- Artifact Badges --%>
                <% session_artifacts = Map.get(@artifacts, session.id, %{}) %>
                <%= if session_artifacts != %{} do %>
                  <div class="flex items-center gap-1.5 px-3 py-1.5 border-t border-base-300/50 overflow-x-auto">
                    <%= for {name, data} <- session_artifacts, data != nil and data != [] and data != %{} do %>
                      <.artifact_badge
                        name={name}
                        data={data}
                        session_id={session.id}
                        active?={
                          @active_artifact != nil and @active_artifact.session_id == session.id and
                            @active_artifact.name == name
                        }
                      />
                    <% end %>
                  </div>
                <% end %>

                <%!-- Input --%>
                <div class="px-3 py-2 border-t border-base-300">
                  <.form
                    for={%{}}
                    id={"msg-form-#{session.id}"}
                    phx-submit="send_message"
                    class="chat-input-wrap"
                  >
                    <input type="hidden" name="message[session_id]" value={session.id} />
                    <textarea
                      id={"chat-input-#{session.id}"}
                      name="message[content]"
                      placeholder="Type a message…"
                      autocomplete="off"
                      rows="1"
                      class="chat-input"
                      phx-hook=".ChatInput"
                    />
                    <button type="submit" class="chat-send-btn" aria-label="Send message">
                      <.icon name="hero-paper-airplane" class="w-4 h-4" />
                    </button>
                  </.form>
                </div>
              </div>
            <% end %>
          </div>

          <%!-- Artifact Side Panel / Task Board (split mode) --%>
          <div class="w-[480px] shrink-0">
            <%= if @show_task_board do %>
              <TaskBoard.board
                tasks={@tasks}
                agent_sessions={@agent_sessions}
                task_form={@task_form}
              />
            <% else %>
              <.artifact_panel
                artifacts={@artifacts}
                active_artifact={@active_artifact}
                agent_sessions={@agent_sessions}
              />
            <% end %>
          </div>
        </div>

        <%!-- ============================================= --%>
        <%!-- UNIFIED MODE                                  --%>
        <%!-- ============================================= --%>
      <% else %>
        <div class="flex-1 flex min-h-0">
          <%!-- Agent Sidebar --%>
          <div class="w-48 shrink-0 border-r border-base-300/50 flex flex-col">
            <div class="px-3 py-2 border-b border-base-300/50">
              <span class="text-[10px] uppercase tracking-wider text-base-content/40">
                Agents
              </span>
            </div>
            <div class="flex-1 overflow-y-auto py-1">
              <%= for session <- @agent_sessions do %>
                <% colors =
                  Catalog.agent_color(
                    session.agent_profile_id,
                    session.display_name
                  ) %>
                <div class="flex items-center justify-between px-3 py-1.5 group">
                  <div class="flex items-center gap-2 min-w-0">
                    <div class={["w-2 h-2 rounded-full shrink-0", colors.dot]}></div>
                    <span class={["text-sm font-medium truncate", colors.text]}>
                      {session.display_name}
                    </span>
                  </div>
                  <div class="flex items-center gap-1 shrink-0">
                    <%= if Map.get(@agent_statuses, session.id) == :busy do %>
                      <span class="loading loading-dots loading-xs text-warning"></span>
                    <% end %>
                    <button
                      phx-click="remove_agent"
                      phx-value-session-id={session.id}
                      data-confirm="Remove this agent?"
                      class="btn btn-ghost btn-xs opacity-0 group-hover:opacity-60 hover:!opacity-100"
                    >
                      <.icon name="hero-x-mark" class="w-3 h-3" />
                    </button>
                  </div>
                </div>
              <% end %>
            </div>
          </div>

          <%!-- Unified Message Stream --%>
          <div class="flex-1 flex flex-col min-w-0">
            <div
              id="unified-messages"
              phx-hook=".AutoScroll"
              class="flex-1 overflow-y-auto px-4 py-3 space-y-3"
            >
              <% timeline = MurmurWeb.WorkspaceLive.unified_timeline(@messages, @agent_sessions) %>
              <%= if timeline == [] and Enum.all?(@streaming, fn {_, s} -> s.content == "" and s.tool_calls == [] end) do %>
                <div class="flex items-center justify-center h-full text-base-content/40 text-sm">
                  Send a message to start chatting. Use @name to target a specific agent.
                </div>
              <% end %>

              <%= for msg <- timeline do %>
                <% colors =
                  Map.get(msg, :agent_color, %{
                    dot: "bg-gray-500",
                    text: "text-base-content",
                    bg: "bg-base-200/50"
                  }) %>
                <div
                  id={"unified-msg-#{msg.id}"}
                  class={[
                    "flex gap-3",
                    if(msg.role == "user", do: "justify-end", else: "justify-start")
                  ]}
                >
                  <%!-- Agent avatar (left side for non-user messages) --%>
                  <%= unless msg.role == "user" do %>
                    <div class="flex flex-col items-center gap-0.5 pt-4 shrink-0">
                      <div class={[
                        "w-7 h-7 rounded-full flex items-center justify-center text-white text-xs font-bold",
                        colors.dot
                      ]}>
                        {String.first(msg.agent_name || "?")}
                      </div>
                    </div>
                  <% end %>

                  <div class={[
                    "flex flex-col gap-0.5 max-w-[70%] min-w-0",
                    if(msg.role == "user", do: "items-end", else: "items-start")
                  ]}>
                    <span class={[
                      "text-[10px] uppercase tracking-wider px-1",
                      if(msg.role == "user", do: "text-base-content/40", else: colors.text)
                    ]}>
                      <%= if msg.role == "user" do %>
                        {msg.sender_name || "You"}
                      <% else %>
                        {msg.agent_name || msg.sender_name || "assistant"}
                      <% end %>
                    </span>

                    <%!-- Thinking trace --%>
                    <%= if Map.get(msg, :thinking) do %>
                      <details class="w-full group">
                        <summary class="flex items-center gap-1.5 cursor-pointer text-xs text-base-content/50 hover:text-base-content/70 px-1 py-0.5 transition-colors">
                          <.icon name="hero-light-bulb" class="w-3 h-3" />
                          <span>Thinking...</span>
                          <.icon
                            name="hero-chevron-right"
                            class="w-3 h-3 transition-transform group-open:rotate-90"
                          />
                        </summary>
                        <div class="mt-1 rounded-lg bg-base-200/50 border border-base-300/50 px-3 py-2 text-xs text-base-content/60 whitespace-pre-wrap break-words">
                          {msg.thinking}
                        </div>
                      </details>
                    <% end %>

                    <%!-- Tool calls --%>
                    <%= for tc <- Map.get(msg, :tool_calls, []) do %>
                      <details class="w-full group">
                        <summary class="flex items-center gap-1.5 cursor-pointer text-xs px-1 py-0.5 transition-colors hover:text-base-content/70">
                          <.icon
                            name="hero-wrench-screwdriver"
                            class="w-3 h-3 text-base-content/50"
                          />
                          <span class="font-medium">{tc.name}</span>
                          <%= cond do %>
                            <% tc.status == :completed -> %>
                              <span class="text-success/70 text-[10px]">Completed</span>
                            <% tc.status == :error -> %>
                              <span class="text-error/70 text-[10px]">Error</span>
                            <% true -> %>
                              <span class="loading loading-spinner loading-xs text-warning">
                              </span>
                          <% end %>
                          <.icon
                            name="hero-chevron-right"
                            class="w-3 h-3 text-base-content/40 transition-transform group-open:rotate-90"
                          />
                        </summary>
                        <div class="mt-1 rounded-lg border border-base-300/50 text-xs overflow-hidden">
                          <%= if tc.args && tc.args != %{} do %>
                            <div class="bg-base-200/30 px-3 py-1.5 border-b border-base-300/50">
                              <span class="text-[10px] uppercase tracking-wider text-base-content/40">
                                Arguments
                              </span>
                              <pre class="mt-0.5 text-base-content/70 whitespace-pre-wrap break-words">{Jason.encode!(tc.args, pretty: true)}</pre>
                            </div>
                          <% end %>
                          <%= if tc.result do %>
                            <div class="bg-base-200/20 px-3 py-1.5">
                              <span class="text-[10px] uppercase tracking-wider text-base-content/40">
                                Result
                              </span>
                              <div class="mt-0.5 text-base-content/70 whitespace-pre-wrap break-words">
                                {tc.result}
                              </div>
                            </div>
                          <% end %>
                        </div>
                      </details>
                    <% end %>

                    <%!-- Message content --%>
                    <%= if msg.content && msg.content != "" do %>
                      <div class={[
                        "rounded-xl px-3 py-2 text-sm break-words",
                        if(msg.role == "user",
                          do: "bg-primary text-primary-content rounded-br-sm whitespace-pre-wrap",
                          else: [
                            colors.bg,
                            "border border-base-300/30 text-base-content rounded-bl-sm prose prose-sm max-w-none"
                          ]
                        )
                      ]}>
                        <%= if msg.role == "user" do %>
                          {msg.content}
                        <% else %>
                          {Markdown.render(msg.content)}
                        <% end %>
                      </div>
                      <%!-- Usage info --%>
                      <%= if Map.get(msg, :usage) do %>
                        <div class="group/usage relative inline-flex items-center px-1">
                          <.icon
                            name="hero-information-circle"
                            class="w-3 h-3 text-base-content/30 hover:text-base-content/60 cursor-help transition-colors"
                          />
                          <div class="absolute bottom-full left-0 mb-1 hidden group-hover/usage:block z-10">
                            <div class="bg-base-300 text-base-content text-[10px] rounded-lg px-2.5 py-1.5 shadow-lg border border-base-content/10 whitespace-nowrap">
                              <div class="flex items-center gap-3">
                                <span>{Map.get(msg.usage, :input_tokens, 0)} in</span>
                                <span>{Map.get(msg.usage, :output_tokens, 0)} out</span>
                                <span class="font-medium">
                                  {Map.get(msg.usage, :total_tokens, 0)} total
                                </span>
                                <%= if Map.get(msg.usage, :duration_ms) do %>
                                  <span class="text-base-content/50">
                                    {Float.round(msg.usage.duration_ms / 1000, 1)}s
                                  </span>
                                <% end %>
                              </div>
                              <%= if Map.get(msg.usage, :model) do %>
                                <div class="text-base-content/50 mt-0.5">{msg.usage.model}</div>
                              <% end %>
                            </div>
                          </div>
                        </div>
                      <% end %>
                    <% end %>
                  </div>
                </div>
              <% end %>

              <%!-- Streaming state for all agents --%>
              <%= for session <- @agent_sessions do %>
                <% stream =
                  Map.get(@streaming, session.id, %{
                    content: "",
                    thinking: "",
                    tool_calls: [],
                    usage: nil
                  }) %>
                <%= if stream.thinking != "" or stream.content != "" or stream.tool_calls != [] do %>
                  <% colors =
                    Catalog.agent_color(
                      session.agent_profile_id,
                      session.display_name
                    ) %>
                  <div class="flex gap-3 justify-start">
                    <div class="flex flex-col items-center gap-0.5 pt-4 shrink-0">
                      <div class={[
                        "w-7 h-7 rounded-full flex items-center justify-center text-white text-xs font-bold",
                        colors.dot
                      ]}>
                        {String.first(session.display_name)}
                      </div>
                    </div>
                    <div class="flex flex-col gap-0.5 max-w-[70%] min-w-0 items-start">
                      <span class={["text-[10px] uppercase tracking-wider px-1", colors.text]}>
                        {session.display_name}
                      </span>

                      <%!-- Thinking trace --%>
                      <%= if stream.thinking != "" do %>
                        <details open class="w-full group">
                          <summary class="flex items-center gap-1.5 cursor-pointer text-xs text-base-content/50 hover:text-base-content/70 px-1 py-0.5 transition-colors">
                            <.icon name="hero-light-bulb" class="w-3 h-3" />
                            <span>Thinking...</span>
                            <span class="loading loading-dots loading-xs text-base-content/40">
                            </span>
                            <.icon
                              name="hero-chevron-right"
                              class="w-3 h-3 transition-transform group-open:rotate-90"
                            />
                          </summary>
                          <div class="mt-1 rounded-lg bg-base-200/50 border border-base-300/50 px-3 py-2 text-xs text-base-content/60 whitespace-pre-wrap break-words">
                            {stream.thinking}
                          </div>
                        </details>
                      <% end %>

                      <%!-- Streaming tool calls --%>
                      <%= for tc <- stream.tool_calls do %>
                        <details open class="w-full group">
                          <summary class="flex items-center gap-1.5 cursor-pointer text-xs px-1 py-0.5 transition-colors hover:text-base-content/70">
                            <.icon
                              name="hero-wrench-screwdriver"
                              class="w-3 h-3 text-base-content/50"
                            />
                            <span class="font-medium">{tc.name}</span>
                            <%= if tc.status == :completed do %>
                              <span class="text-success/70 text-[10px]">Completed</span>
                            <% else %>
                              <span class="text-error/70 text-[10px]">Error</span>
                            <% end %>
                            <.icon
                              name="hero-chevron-right"
                              class="w-3 h-3 text-base-content/40 transition-transform group-open:rotate-90"
                            />
                          </summary>
                          <%= if tc.result do %>
                            <div class="mt-1 rounded-lg border border-base-300/50 text-xs overflow-hidden">
                              <div class="bg-base-200/20 px-3 py-1.5">
                                <span class="text-[10px] uppercase tracking-wider text-base-content/40">
                                  Result
                                </span>
                                <div class="mt-0.5 text-base-content/70 whitespace-pre-wrap break-words">
                                  {tc.result}
                                </div>
                              </div>
                            </div>
                          <% end %>
                        </details>
                      <% end %>

                      <%!-- Content tokens --%>
                      <%= if stream.content != "" do %>
                        <div class={[
                          "rounded-xl rounded-bl-sm px-3 py-2 text-sm whitespace-pre-wrap break-words border border-base-300/30",
                          colors.bg
                        ]}>
                          {stream.content}
                          <span class="inline-block w-1 h-4 bg-primary animate-pulse ml-0.5 align-text-bottom">
                          </span>
                        </div>
                      <% end %>
                    </div>
                  </div>
                <% end %>
              <% end %>
            </div>

            <%!-- Artifact Badges (unified) --%>
            <% all_artifacts =
              Enum.flat_map(@artifacts, fn {sid, arts} ->
                Enum.map(arts, fn {name, data} -> {sid, name, data} end)
              end) %>
            <%= if all_artifacts != [] do %>
              <div class="flex items-center gap-1.5 px-4 py-1.5 border-t border-base-300/50 overflow-x-auto">
                <%= for {sid, name, data} <- all_artifacts, data != nil and data != [] and data != %{} do %>
                  <.artifact_badge
                    name={name}
                    data={data}
                    session_id={sid}
                    active?={
                      @active_artifact != nil and @active_artifact.session_id == sid and
                        @active_artifact.name == name
                    }
                  />
                <% end %>
              </div>
            <% end %>

            <%!-- Unified Input --%>
            <div class="px-4 py-3 border-t border-base-300">
              <.form
                for={%{}}
                id="unified-msg-form"
                phx-submit="send_unified_message"
                class="chat-input-wrap"
              >
                <textarea
                  id="unified-chat-input"
                  name="message[content]"
                  placeholder={"@#{if(hd_session = List.first(@agent_sessions), do: hd_session.display_name, else: "agent")} message… or just type to send to first agent"}
                  autocomplete="off"
                  rows="1"
                  class="chat-input"
                  phx-hook=".ChatInput"
                />
                <button type="submit" class="chat-send-btn" aria-label="Send message">
                  <.icon name="hero-paper-airplane" class="w-4 h-4" />
                </button>
              </.form>
            </div>
          </div>

          <%!-- Artifact Side Panel / Task Board (unified mode) --%>
          <div class="w-[480px] shrink-0">
            <%= if @show_task_board do %>
              <TaskBoard.board
                tasks={@tasks}
                agent_sessions={@agent_sessions}
                task_form={@task_form}
              />
            <% else %>
              <.artifact_panel
                artifacts={@artifacts}
                active_artifact={@active_artifact}
                agent_sessions={@agent_sessions}
              />
            <% end %>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>

  <%!-- Add Agent Dialog --%>
  <dialog id="add-agent-dialog" class="modal">
    <div class="modal-box">
      <h3 class="font-bold text-lg mb-4">Add Agent to Workspace</h3>
      <.form for={@add_agent_form} id="add-agent-form" phx-submit="add_agent" class="space-y-4">
        <div class="form-control">
          <label class="label"><span class="label-text">Agent Profile</span></label>
          <select name="agent[profile_id]" class="select select-bordered w-full" required>
            <option value="" disabled selected>Choose a profile...</option>
            <%= for profile <- @profiles do %>
              <option value={profile.id}>{profile.id} — {profile.description}</option>
            <% end %>
          </select>
        </div>
        <div class="form-control">
          <label class="label"><span class="label-text">Display Name</span></label>
          <input
            type="text"
            name="agent[display_name]"
            class="input input-bordered w-full"
            placeholder="e.g. Research Assistant"
            required
          />
          <label class="label">
            <span class="label-text-alt text-base-content/50">
              Must be unique within this workspace
            </span>
          </label>
        </div>
        <div class="modal-action">
          <button
            type="button"
            class="btn"
            onclick="document.getElementById('add-agent-dialog').close()"
          >
            Cancel
          </button>
          <button
            type="submit"
            class="btn btn-primary"
            onclick="document.getElementById('add-agent-dialog').close()"
          >
            Add Agent
          </button>
        </div>
      </.form>
    </div>
    <form method="dialog" class="modal-backdrop">
      <button>close</button>
    </form>
  </dialog>

  <%!-- ChatInput colocated JS hook: auto-resize, Enter to submit, Shift+Enter for newline, clear on submit --%>
  <script :type={Phoenix.LiveView.ColocatedHook} name=".ChatInput">
    export default {
      mounted() {
        this.form = this.el.closest("form")

        this.el.addEventListener("input", () => this.resize())
        this.el.addEventListener("keydown", (e) => {
          if (e.key === "Enter" && !e.shiftKey) {
            e.preventDefault()
            if (this.el.value.trim() !== "") {
              this.form.requestSubmit()
            }
          }
        })

        this.form.addEventListener("submit", () => {
          requestAnimationFrame(() => {
            this.form.reset()
            this.resize()
          })
        })
      },
      resize() {
        this.el.style.height = "auto"
        const max = 6 * parseFloat(getComputedStyle(this.el).lineHeight || 20)
        this.el.style.height = Math.min(this.el.scrollHeight, max) + "px"
      }
    }
  </script>

  <%!-- AutoScroll colocated JS hook --%>
  <script :type={Phoenix.LiveView.ColocatedHook} name=".AutoScroll">
    export default {
      mounted() {
        this.scrollToBottom()
        this.observer = new MutationObserver(() => this.scrollToBottom())
        this.observer.observe(this.el, { childList: true, subtree: true })
      },
      updated() {
        this.scrollToBottom()
      },
      destroyed() {
        if (this.observer) this.observer.disconnect()
      },
      scrollToBottom() {
        this.el.scrollTop = this.el.scrollHeight
      }
    }
  </script>
</Layouts.app>
